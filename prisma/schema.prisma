// This is the database schema. It defines how our data is structured.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Organization Model (For Multi-Tenant SaaS)
model Organization {
  id            String   @id @default("singleton") // singleton — one row holds our org info
  // ── Identity ──────────────────────────────────────────────────────────────
  name          String
  logo          String? // Cloudinary URL (uploaded via settings page)
  tagline       String?
  description   String? @db.Text
  // ── Contact + Address ─────────────────────────────────────────────────────
  email         String?
  phone         String?
  website       String?
  addressLine   String?
  city          String?
  district      String?
  postalCode    String?
  // ── Legal / Registration ──────────────────────────────────────────────────
  regNo          String? // society/cooperative registration no.
  licenseNo      String?
  tradeLicenseNo String?
  establishedYear String?
  // ── Social (rendered as small links on the receipt footer) ────────────────
  facebook String?
  whatsapp String?
  youtube  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  members   Member[]
}

// Enums
enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  UNMARRIED
  MARRIED
  DIVORCED
  WIDOWED
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum WishType {
  BIRTHDAY
  MARRIAGE
  JOINING
  FESTIVAL
}

enum WishChannel {
  SMS
  EMAIL
  BOTH
}

enum MemberStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
  DECEASED
  CLOSED
  REJECTED
}

// ====================== TRUST SCORE SYSTEM (FRS v2.0) ======================

// Achievement badge award lifecycle for the per-member badge row
enum AchievementBadgeStatus {
  ACTIVE
  LOST
}

// Fine lifecycle (maps to the FINE KPI)
enum FineStatus {
  ISSUED
  PAID
  WAIVED
}

// Meeting attendance value (maps to the ATTEND KPI). EXCUSED counts as attended
// when the admin enables "approved absences count as attended" (default on).
enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
}

// Member Model (Society Members)
model Member {
  id String @id @default(uuid())

  // Link to Organization
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Membership Information
  memberNo       String       @unique
  membershipDate DateTime     @default(now())
  joiningDate    DateTime?
  memberType     String?
  status         MemberStatus @default(PENDING)

  // Personal Information
  firstName String
  lastName  String
  fullName  String

  gender        Gender?
  dateOfBirth   DateTime?
  maritalStatus MaritalStatus?
  marriageDate  DateTime?

  fatherName String?
  motherName String?
  spouseName String?

  religion    String?
  nationality String?     @default("Bangladeshi")
  bloodGroup  BloodGroup?

  occupation    String?
  profession    String?
  monthlyIncome Decimal? @db.Decimal(12, 2)

  // Contact
  phone                String
  emergencyPhone       String?
  emergencyContactName String?
  email                String? @unique

  // Identity
  nidNumber          String? @unique
  passportNumber     String? @unique
  birthCertificateNo String? @unique

  // Bank Information
  accountName   String?
  accountNumber String?
  bankName      String?
  branch        String?
  routingNumber String?

  // Photo
  photoUrl String?

  kycVerified Boolean @default(false)

  // Membership
  remarks String? @db.Text

  // ── Trust Score (FRS v2.0) ──────────────────────────────────────────────
  // All fields are auto-managed by the scoring engine; never edited manually.
  trustScore         Int       @default(60) // 0–100
  badgeLevel         String    @default("Silver Member")
  riskLevel          String    @default("Average")
  scoreLastUpdated   DateTime?
  // Referral: the member who referred this one. Self-referencing relation.
  referredByMemberId String?
  referredBy         Member?   @relation("MemberReferral", fields: [referredByMemberId], references: [id], onDelete: SetNull)
  referrals          Member[]  @relation("MemberReferral")

  // Relationships
  addresses     MemberAddress[]
  nominees      MemberNominee[]
  documents     MemberDocument[]
  accounts      MemberAccount[]
  savings       Savings[]
  ledgerEntries LedgerEntry[]

  // Loan relationships
  loans          Loan[]
  loanRepayments LoanRepayment[]
  loanGuarantors LoanGuarantor[] @relation("LoanGuarantorMember")

  // Special wishes
  wishLogs SpecialWishLog[]

  // Accounting
  journalEntries JournalEntry[]

  // Transactions Module
  transactions Transaction[]

  // Trust Score relationships (FRS v2.0)
  scoreHistory        TrustScoreHistory[]
  achievementBadges   AchievementBadge[]
  fines               Fine[]
  meetingAttendances  MeetingAttendance[]
  memberNotifications MemberNotification[]

  // Audit
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy       String?
  updatedBy       String?
  requests        MemberRequest[]
  profileRequests ProfileUpdateRequest[]

  @@index([memberNo])
  @@index([phone])
  @@index([email])
  @@index([status])
  @@index([joiningDate])
  @@index([trustScore])
}

model MemberAddress {
  id            String   @id @default(uuid())
  memberId      String
  member        Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  addressType   String // CURRENT, PERMANENT
  village       String?
  postOffice    String?
  policeStation String?
  district      String?
  division      String?
  postalCode    String?
  country       String?  @default("Bangladesh")
  createdAt     DateTime @default(now())

  @@index([memberId])
}

model MemberNominee {
  id              String    @id @default(uuid())
  memberId        String
  member          Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  name            String
  relation        String
  phone           String?
  email           String?
  dateOfBirth     DateTime?
  nidNumber       String?
  idType          String? // <-- ADD THIS LINE
  idDocumentUrl   String? // <-- ADD THIS LINE
  sharePercentage Decimal   @db.Decimal(5, 2)
  photoUrl        String?
  documentUrl     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([memberId])
}

model MemberDocument {
  id           String    @id @default(uuid())
  memberId     String
  member       Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  documentType String
  name         String?
  fileName     String?
  fileUrl      String
  issueDate    DateTime?
  expiryDate   DateTime?
  uploadedAt   DateTime  @default(now())

  @@index([memberId])
}

model MemberAccount {
  id            String    @id @default(uuid())
  memberId      String
  member        Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  username      String    @unique
  email         String?   @unique
  passwordHash  String
  emailVerified Boolean   @default(false)
  lastLogin     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([memberId])
}

// Placeholder models so Prisma validation passes
model Savings {
  id        String   @id @default(uuid())
  receiptNo String?  @unique
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  type      String // MONTHLY, DAILY, DONATION, FINE
  method    String // CASH, BKASH, BANK
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  // Transactions Module — the member-facing mirror of an approved Transaction.
  transactionMirror Transaction?

  @@index([memberId])
}

model LedgerEntry {
  id        String   @id @default(uuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  debit     Decimal? @default(0) @db.Decimal(12, 2)
  credit    Decimal? @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
}

// User Model (Admins & Staff)
// role values: SUPER_ADMIN | ADMIN | MEMBER.
//   - SUPER_ADMIN: full override; can edit locked attendance/minutes any time.
//   - ADMIN: dashboard staff. Needs an explicit UserPermission row to submit
//            attendance / upload minutes; submission locks the record.
model User {
  id          String           @id @default(uuid())
  email       String           @unique
  password    String
  role        String           @default("ADMIN") // SUPER_ADMIN, ADMIN, MEMBER
  name        String?
  phone       String?
  isActive    Boolean          @default(true)
  lastLogin   DateTime?
  createdBy   String?
  permissions UserPermission[]

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([isActive])
  @@index([role])
}

// Enums for Accounting
enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum AccountNature {
  DEBIT
  CREDIT
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

// Voucher / journal-entry type for double-entry bookkeeping
enum VoucherType {
  JOURNAL // General journal entry
  RECEIPT // Money received (cash/bank debit)
  PAYMENT // Money paid out (cash/bank credit)
  CONTRA // Between two asset accounts (e.g. bank <-> cash)
}

// Lifecycle of a journal entry
enum JournalStatus {
  DRAFT // Editable, not yet affecting balances
  POSTED // Posted to the ledger; balances updated
}

model Account {
  id              String    @id @default(uuid())
  accountCode     String    @unique
  accountName     String
  parentAccountId String?
  parentAccount   Account?  @relation("AccountTree", fields: [parentAccountId], references: [id], onDelete: SetNull)
  childAccounts   Account[] @relation("AccountTree")

  accountType    AccountType
  category       String?
  nature         AccountNature
  openingBalance Decimal       @default(0) @db.Decimal(12, 2)
  currentBalance Decimal       @default(0) @db.Decimal(12, 2)
  currency       String        @default("BDT")
  description    String?       @db.Text

  isBank       Boolean       @default(false)
  isCash       Boolean       @default(false)
  allowPosting Boolean       @default(true)
  allowJournal Boolean       @default(true)
  status       AccountStatus @default(ACTIVE)

  // Extension fields for enterprise use
  taxDeductible     Boolean  @default(false)
  reconciledBalance Decimal? @db.Decimal(12, 2)

  // Double-entry postings
  journalLines JournalLine[]

  // Transactions Module — the cash/bank/wallet side of transactions
  cashTransactions Transaction[]

  // Somiti Settings → Active Bank Accounts (default COA per payment method)
  bankAccounts BankAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Journal Entry = the voucher header (one document, many lines)
model JournalEntry {
  id          String        @id @default(uuid())
  voucherNo   String        @unique // e.g. JV-0001, RV-0001, PV-0001, CV-0001
  voucherType VoucherType   @default(JOURNAL)
  entryDate   DateTime      @default(now())
  narration   String
  referenceNo String?
  memberId    String? // optional link to a member (e.g. member payment)
  member      Member?       @relation(fields: [memberId], references: [id], onDelete: SetNull)
  status      JournalStatus @default(DRAFT)
  totalDebit  Decimal       @default(0) @db.Decimal(14, 2)
  totalCredit Decimal       @default(0) @db.Decimal(14, 2)

  lines JournalLine[]

  // Transactions Module — the posting created when a transaction is approved
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Journal Line = a single posting (debit OR credit) to one account
model JournalLine {
  id             String       @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Restrict)

  debit  Decimal @default(0) @db.Decimal(14, 2)
  credit Decimal @default(0) @db.Decimal(14, 2)
  memo   String?

  createdAt DateTime @default(now())
}

// ====================== TRANSACTIONS MODULE ======================
// Unified financial engine with Maker-Checker approval workflow and full
// double-entry accounting integration. Every approved transaction writes to
// BOTH the member-facing Savings ledger AND the General Ledger
// (JournalEntry + JournalLine) atomically, linked by shared ids.
// Approved transactions are immutable — corrections require a Reversal.

// The 4 top-level transaction categories (spec §3).
enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  CHARGE
  INCOME_DISTRIBUTION
}

// Detailed sub-types. Member-side and Future-side entries share this enum
// for forward compatibility (loan disbursement, admission fee, shares, etc.
// are stubbed TODO(PHASE 2)).
enum TransactionSubType {
  // Member deposits
  SAVINGS_DEPOSIT
  ADVANCE
  DUE_PAYMENT
  // Charges
  SERVICE_CHARGE
  BANK_CHARGE
  ANNUAL_FEE
  ADMIN_CHARGE
  FINE_PENALTY
  OTHER_CHARGE
  // Income distribution sources
  PROJECT_PROFIT
  BANK_INTEREST
  INVESTMENT_INCOME
  DIVIDEND
  OTHER_INCOME
  // Future (Phase 2 stubs)
  LOAN_DISBURSEMENT
  LOAN_INSTALLMENT
  ADMISSION_FEE
  MEMBERSHIP_FEE
  SHARE_PURCHASE
  SHARE_REFUND
}

// Which ledger this transaction touches.
enum TransactionCategory {
  MEMBER
  FUTURE
}

// Payment / collection method (spec §6).
enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  BKASH
  NAGAD
  ROCKET
}

// Approval workflow status (spec §5).
enum TransactionStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  RETURNED
  REJECTED
  REVERSED
}

// Approval tier resolved at submit time from ApprovalLimit by amount (spec §13).
enum ApprovalLevel {
  L1
  L2
  L3
}

model Transaction {
  id              String              @id @default(uuid())
  voucherNo       String              @unique // TR-DEP-000001 etc. (atomic via Counter)
  transactionType TransactionType
  subType         TransactionSubType
  category        TransactionCategory @default(MEMBER)

  // Member this transaction affects (optional for some charges / distributions).
  memberId String?
  member   Member? @relation(fields: [memberId], references: [id], onDelete: Restrict)

  // Money & payment
  amount        Decimal        @db.Decimal(14, 2)
  paymentMethod PaymentMethod?
  cashAccountId String? // Cash Drawer / Bank / Mobile Wallet (Account)
  cashAccount   Account?       @relation(fields: [cashAccountId], references: [id], onDelete: Restrict)
  referenceNo   String?

  // Structured payload preserving the collection breakdown (deposit, principal,
  // interest, fine, other, discount) or member-wise income-distribution split.
  breakdown   Json?
  attachments Json    @default("[]") // [{type, name, url}]
  remarks     String? @db.Text

  // ── Status workflow ────────────────────────────────────────────────────
  status          TransactionStatus @default(DRAFT)
  approvalLevel   ApprovalLevel?
  returnReason    String?           @db.Text
  rejectionReason String?           @db.Text

  // ── Reversal linkage (spec §19/§29) ────────────────────────────────────
  // reversalOfId: if set, THIS row reverses the referenced transaction.
  // reversedById: set on the original when a reversal is created against it.
  // Self-relation: only one side owns the foreign key.
  reversalOfId   String?      @unique
  reversalOf     Transaction? @relation("TransactionReversal", fields: [reversalOfId], references: [id], onDelete: Restrict)
  reversedById   String?      @unique
  reversedBy     Transaction? @relation("TransactionReversal")
  reversalReason String?      @db.Text

  // ── Posting links (filled atomically on approval) ─────────────────────
  journalEntryId  String?
  journalEntry    JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  savingsMirrorId String?       @unique
  savingsMirror   Savings?      @relation(fields: [savingsMirrorId], references: [id], onDelete: Restrict)

  // ── Member-portal request origin ──────────────────────────────────────
  memberSubmitted Boolean        @default(false)
  memberRequestId String?
  memberRequest   MemberRequest? @relation(fields: [memberRequestId], references: [id], onDelete: SetNull)

  // ── Full audit trail (spec §18) ────────────────────────────────────────
  createdBy        String
  createdById      String
  createdAt        DateTime  @default(now())
  // Effective date of the transaction (when the money moved), separate from the
  // system createdAt. Lets collectors back-date entries recorded after the fact.
  transactionDate  DateTime  @default(now())
  submittedBy      String?
  submittedById    String?
  submittedAt      DateTime?
  approvedBy       String?
  approvedById     String?
  approvedAt       DateTime?
  returnedBy       String?
  returnedById     String?
  returnedAt       DateTime?
  rejectedBy       String?
  rejectedById     String?
  rejectedAt       DateTime?
  reversedByUser   String?
  reversedByUserId String?
  reversedAt       DateTime?
  ipAddress        String?
  deviceInfo       String?

  @@index([status])
  @@index([transactionType, status])
  @@index([memberId])
  @@index([approvedAt])
  @@index([reversalOfId])
  @@index([cashAccountId])
}

// Approval tier configuration (spec §13). Resolved at submit time by amount.
// role values: SUPER_ADMIN | ADMIN. ADMIN rows additionally require the named
// permission key on the UserPermission table.
model ApprovalLimit {
  id         String   @id @default(uuid())
  level      Int // 1, 2, 3
  label      String // "Branch Manager", "Regional Manager", "Super Admin"
  role       String // SUPER_ADMIN | ADMIN
  // When role=ADMIN, this permission key (on UserPermission) is also required.
  permission String?
  minAmount  Decimal  @default(0) @db.Decimal(14, 2)
  maxAmount  Decimal  @db.Decimal(14, 2)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([level, isActive])
}

// Atomic monotonic sequence counters — fixes the race-prone `count+1` voucher
// generation. Each id (e.g. "transaction", "TR-DEP") is incremented inside a
// `prisma.$transaction` with the row locked for update.
model Counter {
  id    String @id
  value Int    @default(0)
}

model SiteContent {
  id            String   @id @default("singleton")
  heroTitle     String   @default("The Modern Way to Manage Your Somiti")
  heroSubtitle  String   @default("Digitize your cooperative society. Automate collections, track ledgers, and build financial trust with complete transparency.")
  aboutTitle    String   @default("About Our Somiti")
  aboutContent  String   @default("We are a community-driven cooperative society dedicated to empowering our members financially. Founded on principles of trust and mutual support, we provide a secure platform for savings, loans, and investments.")
  visionTitle   String   @default("Our Vision & Mission")
  visionContent String   @default("To build a financially resilient community where every member has access to transparent, secure, and modern financial services, fostering growth and prosperity for all.")
  whyJoinUs     Json     @default("[]") // Array of {icon, title, description}
  howWeRun      Json     @default("[]") // Array of {step, title, description}
  transparency  String   @default("100% Transparency in Somiti Management. All transactions are recorded in real-time ledgers. Members have 24/7 access to their balances, and automated receipts ensure accountability for every Taka.")
  policyContent String?  @db.Text // <-- ADD THIS LINE
  facilities    Json     @default("[]") // Array of {icon, title, description}
  management    Json     @default("[]") // Array of {name, role, photoUrl, bio}
  activities    Json     @default("[]") // Array of {title, date, description}
  projects      Json     @default("[]") // Array of {title, status, description}
  updatedAt     DateTime @updatedAt
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  type      String   @default("SYSTEM") // SYSTEM, SMS_ERROR
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Festival {
  id        String   @id @default(uuid())
  name      String
  month     Int // 1-12
  day       Int // 1-31
  message   String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wishLogs SpecialWishLog[]

  @@index([month, day])
  @@index([isActive])
}

model SpecialWishLog {
  id         String      @id @default(uuid())
  type       WishType
  memberId   String?
  member     Member?     @relation(fields: [memberId], references: [id], onDelete: SetNull)
  festivalId String?
  festival   Festival?   @relation(fields: [festivalId], references: [id], onDelete: SetNull)
  message    String      @db.Text
  channel    WishChannel
  status     String // SENT, FAILED
  error      String?     @db.Text
  sentAt     DateTime    @default(now())

  @@index([type])
  @@index([memberId])
  @@index([festivalId])
  @@index([sentAt])
}

model MemberRequest {
  id        String   @id @default(uuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  type      String // WITHDRAWAL, CLOSING
  amount    Decimal? @db.Decimal(12, 2)
  method    String?
  reason    String?
  notes     String?
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())

  // Transactions Module — a portal request may be approved into a Transaction.
  transactions Transaction[]
}

// Meeting minutes + attendance submission lifecycle.
//   - Attendance: an authorized user submits once -> attendanceLocked=true.
//   - Minutes:    an authorized user uploads once -> minutesLocked=true.
//   - After lock: only SUPER_ADMIN can edit attendance or replace minutes.
model Meeting {
  id          String              @id @default(uuid())
  title       String
  date        DateTime
  // type: ONLINE | OFFLINE. location is used for OFFLINE, link for ONLINE.
  type        String              @default("OFFLINE")
  location    String?
  link        String?
  agenda      String              @db.Text
  createdAt   DateTime            @default(now())
  attendances MeetingAttendance[]

  // Attendance submission lifecycle
  attendanceLocked      Boolean   @default(false)
  attendanceSubmittedAt DateTime?
  attendanceSubmittedBy String?

  // Meeting minutes file
  minutesUrl        String?
  minutesFileName   String?
  minutesUploadedAt DateTime?
  minutesUploadedBy String?
  minutesLocked     Boolean   @default(false)
}

// Per-user permission grants (the "authorized normal users" of rules 5 & 6).
// permission values: MEETING_ATTENDANCE_MARK | MEETING_MINUTES_UPLOAD.
model UserPermission {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission String
  createdAt  DateTime @default(now())

  @@unique([userId, permission])
  @@index([userId])
}

model ProfileUpdateRequest {
  id        String   @id @default(uuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  payload   Json // Stores the requested changes as JSON
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())
}

model FeeSetup {
  id              String   @id @default(uuid())
  name            String
  amount          Decimal  @db.Decimal(12, 2)
  effectiveDate   DateTime
  frequency       String   @default("MONTHLY") // WEEKLY, MONTHLY, QUARTERLY, HALF_YEARLY, YEARLY
  dueDay          Int      @default(10) // 1-31 for months, 0-6 for weekdays (0=Sun, 6=Sat)
  hasFine         Boolean  @default(false)
  fineAmount      Decimal? @db.Decimal(12, 2)
  boardApproved   Boolean  @default(false)
  createdAt       DateTime @default(now())
  targetType      String   @default("ALL") // ALL, SPECIFIC
  targetMemberIds String? // Stores a JSON array of member IDs if SPECIFIC
}

model ChargeType {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ====================== SOMITI SETTINGS — BANK ACCOUNTS ======================
// Backs the "Somiti Settings → Active Bank Accounts" page. Each row maps a
// payment method (Cash / Bank / Mobile) to a Chart-of-Accounts (COA) Account
// that should receive deposits made via that method. The Deposit form reads
// the default BankAccount for the chosen method to auto-select the COA.

model BankAccount {
  id            String        @id @default(uuid())
  accountName   String                        // e.g. "Cash Drawer — Counter 1"
  bankName      String?                       // e.g. "City Bank" (null for cash/mobile)
  accountNumber String?                       // masked account / wallet number
  branch        String?

  // Granular PaymentMethod (kept consistent with Transaction.paymentMethod so
  // the same enum drives both the deposit form and the default-COA lookup).
  paymentMethod PaymentMethod

  // The Chart-of-Accounts account that receives the deposit (Dr side).
  coaAccountId String
  coaAccount   Account @relation(fields: [coaAccountId], references: [id], onDelete: Restrict)

  isActive  Boolean @default(true)
  // Only one BankAccount should be the default per paymentMethod group
  // (CASH / BANK_TRANSFER+CHEQUE / BKASH+NAGAD+ROCKET). Enforced by the
  // server actions via setDefaultBankAccount().
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([paymentMethod, isActive])
  @@index([coaAccountId])
}

// ====================== LOAN MANAGEMENT ======================

// Enums
enum LoanRepaymentFreq {
  DAILY
  WEEKLY
  FORTNIGHTLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum InterestType {
  FLAT
  REDUCING
}

enum LoanStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
  REPAID
  CLOSED
  DEFAULTED
  WRITTEN_OFF
}

enum InstallmentStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  WAIVED
}

// Loan Product (template defining rules/terms)
model LoanProduct {
  id                   String            @id @default(uuid())
  name                 String            @unique
  code                 String?           @unique // e.g. MLP-01
  description          String?           @db.Text
  minAmount            Decimal           @default(0) @db.Decimal(12, 2)
  maxAmount            Decimal           @db.Decimal(12, 2)
  interestRate         Decimal           @db.Decimal(6, 2) // annual %
  interestType         InterestType      @default(FLAT)
  repaymentFreq        LoanRepaymentFreq @default(MONTHLY)
  numberOfInstallments Int // default tenure
  gracePeriod          Int               @default(0) // days
  lateFinePerDay       Decimal?          @db.Decimal(10, 2)
  allowEarlySettlement Boolean           @default(true)
  allowInterestWaiver  Boolean           @default(false)
  allowReschedule      Boolean           @default(false)
  allowManualSchedule  Boolean           @default(false)
  processingFee        Decimal           @default(0) @db.Decimal(12, 2)
  isActive             Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  loans                Loan[]
}

// Loan (an actual loan record against a member)
model Loan {
  id        String      @id @default(uuid())
  loanNo    String      @unique // L0001 (auto)
  memberId  String
  member    Member      @relation(fields: [memberId], references: [id])
  productId String
  product   LoanProduct @relation(fields: [productId], references: [id])

  // Snapshot of terms at creation (product may change later)
  principal            Decimal           @db.Decimal(12, 2)
  interestRate         Decimal           @db.Decimal(6, 2)
  interestType         InterestType
  repaymentFreq        LoanRepaymentFreq
  numberOfInstallments Int
  totalInterest        Decimal           @default(0) @db.Decimal(12, 2)
  totalPayable         Decimal           @default(0) @db.Decimal(12, 2)
  installmentAmount    Decimal           @default(0) @db.Decimal(12, 2)
  processingFee        Decimal           @default(0) @db.Decimal(12, 2)
  gracePeriod          Int               @default(0)
  lateFinePerDay       Decimal?          @db.Decimal(10, 2)

  // Lifecycle dates
  applicationDate    DateTime   @default(now())
  approvedDate       DateTime?
  disbursedDate      DateTime?
  expectedCloseDate  DateTime?
  closedDate         DateTime?
  status             LoanStatus @default(PENDING)
  disbursementMethod String? // CASH BKASH BANK

  purpose String? @db.Text
  notes   String? @db.Text

  // Running balances
  principalPaid      Decimal   @default(0) @db.Decimal(12, 2)
  interestPaid       Decimal   @default(0) @db.Decimal(12, 2)
  finePaid           Decimal   @default(0) @db.Decimal(12, 2)
  outstandingBalance Decimal   @default(0) @db.Decimal(12, 2)
  nextDueDate        DateTime?

  schedule   LoanSchedule[]
  repayments LoanRepayment[]
  guarantors LoanGuarantor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@index([status])
  @@index([loanNo])
}

// Loan Schedule (amortization installments)
model LoanSchedule {
  id                String            @id @default(uuid())
  loanId            String
  loan              Loan              @relation(fields: [loanId], references: [id], onDelete: Cascade)
  installmentNo     Int
  dueDate           DateTime
  principal         Decimal           @db.Decimal(12, 2)
  interest          Decimal           @db.Decimal(12, 2)
  installmentAmount Decimal           @db.Decimal(12, 2)
  balanceAfter      Decimal           @db.Decimal(12, 2)
  status            InstallmentStatus @default(PENDING)
  paidDate          DateTime?
  paidAmount        Decimal           @default(0) @db.Decimal(12, 2)
  fine              Decimal           @default(0) @db.Decimal(12, 2)

  @@index([loanId])
  @@index([status])
}

// Loan Repayment (a payment record, mirrored to Savings as LOAN_PAYMENT)
model LoanRepayment {
  id              String   @id @default(uuid())
  receiptNo       String?  @unique // RPN-0001
  loanId          String
  loan            Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  memberId        String
  member          Member   @relation(fields: [memberId], references: [id])
  installmentNo   Int?
  principal       Decimal  @default(0) @db.Decimal(12, 2)
  interest        Decimal  @default(0) @db.Decimal(12, 2)
  fine            Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal  @db.Decimal(12, 2)
  method          String // CASH BKASH BANK
  referenceNo     String?
  paymentDate     DateTime @default(now())
  notes           String?
  savingsMirrorId String? // id of the mirrored Savings row
  createdAt       DateTime @default(now())

  @@index([loanId])
  @@index([memberId])
  @@index([paymentDate])
}

// Loan Guarantor
model LoanGuarantor {
  id        String   @id @default(uuid())
  loanId    String
  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  memberId  String? // if guarantor is a registered member
  member    Member?  @relation("LoanGuarantorMember", fields: [memberId], references: [id])
  name      String
  relation  String?
  phone     String?
  nidNumber String?
  address   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([loanId])
}

// ====================== TRUST SCORE SYSTEM MODELS (FRS v2.0) ======================
// PKs are UUIDs (codebase convention). The FRS's INT/BIGINT PKs are adapted;
// functionality is equivalent. See FRS §16.

// Single active configuration row (FRS §16.4 / §12). Always one row, id = "singleton".
// Every weight, threshold, penalty, and badge criterion is read from here at runtime
// (FRS §23.1: "Never hardcode formulas").
model KpiConfiguration {
  id                    String    @id @default("singleton")
  // KPI weights — must always sum to 100 (validated on save).
  depositWeight         Int       @default(35)
  loanWeight            Int       @default(25)
  attendanceWeight      Int       @default(20)
  fineWeight            Int       @default(10)
  referralWeight        Int       @default(10)
  // New-member starting score (FRS §3).
  initialScore          Int       @default(60)
  // Suspension / reactivation thresholds (FRS §9).
  suspensionThreshold   Int       @default(40)
  reactivationThreshold Int       @default(50)
  // Trust-score badge tier minimums (FRS §4). Non-overlapping, span 0–100.
  badgeDiamondMin       Int       @default(90)
  badgePlatinumMin      Int       @default(80)
  badgeGoldMin          Int       @default(70)
  badgeSilverMin        Int       @default(60)
  badgeWarningMin       Int       @default(50)
  badgeHighRiskMin      Int       @default(40)
  // ATTEND KPI behavior (FRS §5.4).
  approvedAbsenceCounts Boolean   @default(true)
  // Deposit interpolation (FRS §5.2): true = linear interpolation, false = lower threshold.
  depositLinearInterp   Boolean   @default(true)
  // Recovery window (months) after a loan default before the LOAN KPI can climb off zero.
  loanRecoveryMonths    Int       @default(6)
  updatedAt             DateTime?
  updatedBy             String?
}

// Immutable Trust Score audit log (FRS §15). Inserted in the same $transaction
// as the member score update (FRS §7 step 9 / §23.2).
// IMPORTANT: there is intentionally NO update / delete path in the application.
// For database-level hardening, run (one-time, by an admin):
//   REVOKE UPDATE, DELETE ON "TrustScoreHistory" FROM PUBLIC;
model TrustScoreHistory {
  id            String   @id @default(uuid())
  memberId      String
  member        Member   @relation(fields: [memberId], references: [id], onDelete: Restrict)
  eventType     String // e.g. DEPOSIT_COLLECTED, FINE_ISSUED, LOAN_DEFAULT, MEMBER_SUSPENDED
  referenceId   String? // id of the triggering record (savings/fine/loan/…)
  referenceType String? // deposit | loan | fine | meeting | referral | member | config
  kpiAffected   String? // DEPOSIT | LOAN | ATTEND | FINE | REFERRAL | ALL | NONE
  scoreBefore   Int
  scoreChange   Int // signed (+/-)
  scoreAfter    Int
  remarks       String?  @db.Text
  createdAt     DateTime @default(now())
  createdBy     String   @default("SYSTEM") // SYSTEM or a user id

  @@index([memberId, createdAt(sort: Desc)])
  @@index([eventType])
}

// Achievement badges (FRS §10). Independent of the Trust Score badge tier.
// A member may hold many at once. Lost badges are kept for history.
model AchievementBadge {
  id         String                 @id @default(uuid())
  memberId   String
  member     Member                 @relation(fields: [memberId], references: [id], onDelete: Cascade)
  badgeCode  String // e.g. DIAMOND_SAVER, PERFECT_PAYER, …
  badgeName  String
  earnedDate DateTime               @default(now())
  lostDate   DateTime?
  status     AchievementBadgeStatus @default(ACTIVE)

  @@unique([memberId, badgeCode, status])
  @@index([memberId, status])
  @@index([badgeCode, status])
}

// Configurable fine categories (FRS §12.3). The penaltyPoints feed the FINE KPI.
model FineType {
  id            String   @id @default(uuid())
  typeName      String   @unique
  penaltyPoints Int // must be > 0
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  fines         Fine[]
}

// A fine issued to a member. Only ISSUED (unresolved) fines deduct from the
// FINE KPI; PAID/WAIVED reverse the penalty (FRS §5.5).
model Fine {
  id            String     @id @default(uuid())
  memberId      String
  member        Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  fineTypeId    String
  fineType      FineType   @relation(fields: [fineTypeId], references: [id], onDelete: Restrict)
  amount        Decimal    @default(0) @db.Decimal(12, 2)
  status        FineStatus @default(ISSUED)
  issuedDate    DateTime   @default(now())
  resolvedDate  DateTime?
  referenceType String? // savings | manual | fee
  referenceId   String?
  notes         String?    @db.Text
  createdBy     String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([memberId, status])
  @@index([fineTypeId])
}

// Per-member attendance for a meeting (FRS §5.4).
model MeetingAttendance {
  id        String           @id @default(uuid())
  meetingId String
  meeting   Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  status    AttendanceStatus @default(PRESENT)
  markedAt  DateTime         @default(now())
  markedBy  String?

  @@unique([meetingId, memberId])
  @@index([memberId])
}

// Persistent per-member notifications (FRS §14). Async, non-blocking.
model MemberNotification {
  id        String   @id @default(uuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  type      String // SCORE_DECREASED | SCORE_INCREASED | BADGE_UPGRADED | BADGE_DOWNGRADED | ACHIEVEMENT_EARNED | ACHIEVEMENT_LOST | AUTO_SUSPENDED | REACTIVATED
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([memberId, isRead, createdAt(sort: Desc)])
}
